---
import { Check, Phone } from 'lucide-react';
import { membershipIntro, memberships, business } from '../../data/siteData';
---

<section id="membership" class="scroll-mt-24 bg-charcoal text-sand py-[var(--spacing-section)]">
  <div class="container-px reveal">
    <!-- Header -->
    <div class="mx-auto max-w-2xl text-center">
      <p class="eyebrow mb-4 text-gold">{membershipIntro.eyebrow}</p>

      <h2 class="display-heading text-3xl sm:text-4xl lg:text-5xl">
        {membershipIntro.title}
      </h2>

      <p class="mt-6 text-lg leading-relaxed text-sand/80">
        {membershipIntro.description}
      </p>
    </div>

    <!-- Membership cards -->
    <div class="mx-auto mt-14 grid max-w-4xl gap-6 md:grid-cols-2">
      {
        memberships.map((m) => (
          <div
            class={`relative flex flex-col rounded-[var(--radius-card)] border p-8 ${
              m.featured
                ? 'border-gold bg-charcoal-deep/70 shadow-2xl shadow-black/30'
                : 'border-sand/10 bg-charcoal-deep/50'
            }`}
          >
            {m.featured && (
              <span class="absolute -top-3 right-6 rounded-full bg-gold px-4 py-1 text-xs font-semibold uppercase tracking-widest text-charcoal">
                Most Popular
              </span>
            )}

            <h3 class="display-heading text-2xl text-sand">{m.name}</h3>

            <p class="mt-4 flex items-baseline gap-2">
              <span class="text-4xl font-semibold text-gold">{m.price}</span>
              <span class="text-sm text-sand/60">{m.cadence}</span>
            </p>

            <p class="mt-4 text-sm uppercase tracking-widest text-gold">{m.tagline}</p>

            <p class="mt-3 leading-relaxed text-sand/80">{m.description}</p>

            <ul class="mt-7 space-y-3">
              {m.perks.map((perk) => (
                <li class="flex items-start gap-3 text-sand/90">
                  <Check size={18} strokeWidth={2} className="mt-0.5 shrink-0 text-gold" />
                  <span>{perk}</span>
                </li>
              ))}
            </ul>

            <div class="mt-8 pt-2">
              <a
                href={business.phoneHref}
                data-call="membership"
                class={m.featured ? 'btn btn-on-dark w-full' : 'btn btn-ghost-dark w-full'}
              >
                <Phone size={18} strokeWidth={1.8} /> Call to Join
              </a>
            </div>
          </div>
        ))
      }
    </div>

    <!-- Footnote -->
    <p class="mx-auto mt-8 max-w-2xl text-center text-sm text-sand/60">
      Start your membership in-studio or by phone — {business.phone}.
    </p>
  </div>
</section>
