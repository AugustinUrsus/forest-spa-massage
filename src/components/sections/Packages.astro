---
import { packages, bookingUrl } from '../../data/siteData';
import PackageSelector from '../react/PackageSelector.tsx';

// Precompute each tier's Fresha deep link before handing off to the island.
const data = packages.map((p) => ({
  name: p.name,
  icon: p.icon,
  blurb: p.blurb,
  tiers: p.tiers.map((t) => ({
    tier: t.tier,
    price: t.price,
    value: t.value,
    duration: t.duration,
    inclusions: t.inclusions,
    href: bookingUrl(t.id),
  })),
}));
---

<section id="packages" class="bg-cloud py-[var(--spacing-section)]">
  <div class="container-px reveal">
    <header class="mx-auto mb-16 max-w-2xl text-center">
      <p class="eyebrow mb-4">Packages</p>
      <h2 class="display-heading text-3xl sm:text-4xl lg:text-5xl">Curated ritual packages</h2>
      <p class="mt-5 text-lg leading-relaxed text-ink-soft">
        Every package comes in two or three tiers — choose your depth of escape, from a
        focused reset to our most complete head-to-toe retreat.
      </p>
    </header>

    <PackageSelector client:visible packages={data} />
  </div>
</section>
