---
import { Phone, CalendarHeart } from 'lucide-react';
import { business, booking, navLinks, baseUrl } from '../../data/siteData';
import BrandMark from '../BrandMark.astro';
import MobileNav from '../react/MobileNav.tsx';
---

<!--
  Translucent frosted header (alpha bg + backdrop blur incl. the -webkit- prefix),
  padding the safe-area so it also frosts the status-bar region. Content runs
  edge-to-edge (viewport-fit=cover) and blurs underneath it.
-->
<header
  id="site-header"
  class="fixed inset-x-0 top-0 z-30 border-b border-black/5 bg-sand/70 text-ink backdrop-blur-md [-webkit-backdrop-filter:blur(14px)] pt-[env(safe-area-inset-top)] transition-shadow duration-300 will-change-transform data-[scrolled]:shadow-md data-[scrolled]:shadow-charcoal/5"
>
  <div class="container-px flex h-16 items-center justify-between gap-6">
    <!-- Brand -->
    <a href={`${baseUrl}#top`} aria-label="Forest Spa home" class="flex items-center">
      <BrandMark variant="horizontal" class="h-12 w-auto sm:h-14" />
    </a>

    <!-- Desktop nav -->
    <nav aria-label="Primary" class="hidden lg:flex lg:items-center lg:gap-5 xl:gap-7">
      {
        navLinks.map((link) => (
          <a href={link.href} class="text-sm font-medium text-ink transition-colors hover:text-bronze">
            {link.label}
          </a>
        ))
      }
    </nav>

    <!-- Desktop CTAs -->
    <div class="hidden lg:flex lg:items-center lg:gap-3">
      <a
        href={business.phoneHref}
        data-call="header"
        class="btn btn-outline"
        aria-label={`Call Forest Spa at ${business.phone}`}
      >
        <Phone size={18} strokeWidth={1.6} />
        <span class="hidden xl:inline">{business.phone}</span>
      </a>
      <a
        href={booking.primary}
        target="_blank"
        rel="noopener"
        data-book="header"
        class="btn btn-primary"
      >
        <CalendarHeart size={18} strokeWidth={1.6} /> Book Now
      </a>
    </div>

    <!-- Mobile nav island (renders its own lg:hidden wrapper + drawer; only hydrates below lg) -->
    <MobileNav
      client:media="(max-width: 1023px)"
      links={navLinks}
      bookUrl={booking.primary}
      phone={business.phone}
      phoneHref={business.phoneHref}
    />
  </div>
</header>

<script>
  const header = document.getElementById('site-header');
  const themeMeta = document.querySelector('meta[name="theme-color"]');
  const sections = Array.from(document.querySelectorAll('section, footer'));
  if (header) {
    const mq = window.matchMedia('(max-width: 1023px)');
    let lastY = Math.max(0, window.scrollY);
    let translate = 0; // 0 = shown · offsetHeight = hidden (slid up), tracks the swipe
    let ticking = false;

    const frame = () => {
      ticking = false;
      const y = Math.max(0, window.scrollY);
      if (y > 8) header.setAttribute('data-scrolled', '');
      else header.removeAttribute('data-scrolled');

      // Header follows the scroll gesture on phones (enters/exits with the swipe).
      if (mq.matches && !document.body.classList.contains('drawer-open')) {
        const max = header.offsetHeight;
        translate = Math.min(max, Math.max(0, translate + (y - lastY)));
        if (y <= 4) translate = 0;
        header.style.transform = `translate3d(0, ${-translate}px, 0)`;
      } else {
        header.style.transform = '';
        translate = 0;
      }

      // Option A: retint the page background + theme-color to the section under the
      // viewport, so the iOS safe-area bars (behind the island / URL bar) match it.
      if (themeMeta && sections.length) {
        const mid = window.innerHeight / 2;
        for (const el of sections) {
          const r = el.getBoundingClientRect();
          if (r.top <= mid && r.bottom > mid) {
            const bg = getComputedStyle(el).backgroundColor;
            if (bg && bg !== 'rgba(0, 0, 0, 0)' && bg !== 'transparent') {
              document.documentElement.style.backgroundColor = bg;
              document.body.style.backgroundColor = bg;
              themeMeta.setAttribute('content', bg);
            }
            break;
          }
        }
      }
      lastY = y;
    };

    const onScroll = () => {
      if (!ticking) {
        ticking = true;
        requestAnimationFrame(frame);
      }
    };
    frame();
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', () => requestAnimationFrame(frame), { passive: true });
    mq.addEventListener('change', frame);
  }
</script>
