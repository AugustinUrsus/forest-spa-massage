---
import { Phone, CalendarHeart } from 'lucide-react';
import { business, booking, navLinks, baseUrl } from '../../data/siteData';
import BrandMark from '../BrandMark.astro';
import MobileNav from '../react/MobileNav.tsx';
---

<!--
  Outer <header> is transparent and only pads the safe-area (behind the dynamic
  island / status bar stays see-through, edge-to-edge). The inner bar is the
  opaque banner (logo + menu). Translating the whole header hides the opaque bar
  and leaves the notch area transparent.
-->
<header
  id="site-header"
  class="fixed inset-x-0 top-0 z-30 pt-[env(safe-area-inset-top)] transition-transform duration-500 ease-[cubic-bezier(0.16,1,0.3,1)] will-change-transform data-[hidden]:-translate-y-full"
>
  <div
    id="site-header-bar"
    class="border-b border-black/5 bg-sand text-ink transition-shadow duration-300 data-[scrolled]:shadow-md data-[scrolled]:shadow-charcoal/5"
  >
    <div class="container-px flex h-16 items-center justify-between gap-6">
      <!-- Brand -->
      <a href={`${baseUrl}#top`} aria-label="Forest Spa home" class="flex items-center">
        <BrandMark variant="horizontal" class="h-12 w-auto sm:h-14" />
      </a>

      <!-- Desktop nav -->
      <nav aria-label="Primary" class="hidden lg:flex lg:items-center lg:gap-5 xl:gap-7">
        {
          navLinks.map((link) => (
            <a
              href={link.href}
              class="text-sm font-medium text-ink transition-colors hover:text-bronze"
            >
              {link.label}
            </a>
          ))
        }
      </nav>

      <!-- Desktop CTAs -->
      <div class="hidden lg:flex lg:items-center lg:gap-3">
        <a
          href={business.phoneHref}
          data-call="header"
          class="btn btn-outline"
          aria-label={`Call Forest Spa at ${business.phone}`}
        >
          <Phone size={18} strokeWidth={1.6} />
          <span class="hidden xl:inline">{business.phone}</span>
        </a>
        <a
          href={booking.primary}
          target="_blank"
          rel="noopener"
          data-book="header"
          class="btn btn-primary"
        >
          <CalendarHeart size={18} strokeWidth={1.6} /> Book Now
        </a>
      </div>

      <!-- Mobile nav island (renders its own lg:hidden wrapper + drawer; only hydrates below lg) -->
      <MobileNav
        client:media="(max-width: 1023px)"
        links={navLinks}
        bookUrl={booking.primary}
        phone={business.phone}
        phoneHref={business.phoneHref}
      />
    </div>
  </div>
</header>

<script>
  const header = document.getElementById('site-header');
  const bar = document.getElementById('site-header-bar');
  const themeMeta = document.querySelector('meta[name="theme-color"]');
  if (header && bar) {
    // Smoothness on iOS (incl. 120Hz ProMotion): moving a fixed element per-scroll
    // is composited separately from the native scroll and always stutters. Instead
    // we toggle a GPU-composited CSS transform transition based on scroll direction —
    // the slide is driven by the compositor, so it stays buttery at any refresh rate.
    const mq = window.matchMedia('(max-width: 1023px)');
    const themed = Array.from(document.querySelectorAll('section, footer'));
    let lastY = Math.max(0, window.scrollY);
    let ticking = false;

    const frame = () => {
      ticking = false;
      const y = Math.max(0, window.scrollY);
      if (y > 8) bar.setAttribute('data-scrolled', '');
      else bar.removeAttribute('data-scrolled');

      if (mq.matches && !document.body.classList.contains('drawer-open')) {
        if (y > lastY + 4 && y > 90) header.setAttribute('data-hidden', ''); // down → hide
        else if (y < lastY - 4 || y < 90) header.removeAttribute('data-hidden'); // up / top → show
      } else {
        header.removeAttribute('data-hidden');
      }

      // Tint the iOS status bar / URL bar to match the section under it, so the
      // safe areas blend into the content instead of showing a solid sand frame.
      if (themeMeta) {
        for (const el of themed) {
          const r = el.getBoundingClientRect();
          if (r.top <= 1 && r.bottom > 1) {
            const bg = getComputedStyle(el).backgroundColor;
            if (bg && bg !== 'rgba(0, 0, 0, 0)' && bg !== 'transparent') {
              themeMeta.setAttribute('content', bg);
            }
            break;
          }
        }
      }
      lastY = y;
    };

    const onScroll = () => {
      if (!ticking) {
        ticking = true;
        requestAnimationFrame(frame);
      }
    };
    frame();
    window.addEventListener('scroll', onScroll, { passive: true });
    mq.addEventListener('change', frame);
  }
</script>
