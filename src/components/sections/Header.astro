---
import { Phone, CalendarHeart } from 'lucide-react';
import { business, booking, navLinks, baseUrl } from '../../data/siteData';
import BrandMark from '../BrandMark.astro';
import MobileNav from '../react/MobileNav.tsx';
---

<!--
  Solid header banner. On phones it hides/shows with a GPU-composited transform
  transition (smooth at any refresh rate, incl. 120Hz) toggled by scroll
  direction. Pads the safe-area so the logo clears the status bar.
-->
<header
  id="site-header"
  class="fixed inset-x-0 top-0 z-30 bg-sand text-ink pt-[env(safe-area-inset-top)] transition-[translate,box-shadow] duration-[450ms] ease-[cubic-bezier(0.4,0,0.2,1)] will-change-transform data-[hidden]:-translate-y-full data-[scrolled]:shadow-md data-[scrolled]:shadow-charcoal/5"
>
  <div class="container-px flex h-16 items-center justify-between gap-4 xl:gap-6">
    <!-- Brand -->
    <a href={`${baseUrl}#top`} aria-label="Forest Spa home" class="flex items-center">
      <BrandMark variant="horizontal" class="h-12 w-auto sm:h-14" />
    </a>

    <!-- Desktop nav -->
    <nav aria-label="Primary" class="hidden lg:flex lg:items-center lg:gap-4 xl:gap-5">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            data-nav-link
            class="whitespace-nowrap text-sm font-medium text-ink transition-colors hover:text-bronze data-[active]:font-semibold data-[active]:text-bronze"
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <!-- Desktop CTAs -->
    <div class="hidden lg:flex lg:items-center lg:gap-3">
      <a
        href={business.phoneHref}
        data-call="header"
        class="btn btn-outline hidden px-5 py-2.5 text-sm xl:inline-flex"
        aria-label={`Call Forest Spa at ${business.phone}`}
      >
        <Phone size={17} strokeWidth={1.6} />
        <span>{business.phone}</span>
      </a>
      <a
        href={booking.primary}
        target="_blank"
        rel="noopener"
        data-book="header"
        class="btn btn-primary px-5 py-2.5 text-sm"
      >
        <CalendarHeart size={17} strokeWidth={1.6} /> Book Now
      </a>
    </div>

    <!-- Mobile nav island (renders its own lg:hidden wrapper + drawer; only hydrates below lg) -->
    <MobileNav
      client:media="(max-width: 1023px)"
      links={navLinks}
      bookUrl={booking.primary}
      phone={business.phone}
      phoneHref={business.phoneHref}
    />
  </div>
</header>

<script>
  const header = document.getElementById('site-header');
  const themeMeta = document.querySelector('meta[name="theme-color"]');
  const sections = Array.from(document.querySelectorAll('section, footer'));
  if (header) {
    const mq = window.matchMedia('(max-width: 1023px)');
    let lastY = Math.max(0, window.scrollY);
    let ticking = false;

    const frame = () => {
      ticking = false;
      const y = Math.max(0, window.scrollY);
      if (y > 8) header.setAttribute('data-scrolled', '');
      else header.removeAttribute('data-scrolled');

      // Smooth compositor-driven hide/show, toggled by scroll direction (phones).
      if (mq.matches && !document.body.classList.contains('drawer-open')) {
        if (y > lastY + 4 && y > 90) header.setAttribute('data-hidden', ''); // down → hide
        else if (y < lastY - 4 || y < 90) header.removeAttribute('data-hidden'); // up / top → show
      } else {
        header.removeAttribute('data-hidden');
      }

      // Option A: retint <html>/<body> + theme-color to the section under the
      // viewport, so the iOS safe-area bars match the content, not a fixed sand frame.
      if (themeMeta && sections.length) {
        const mid = window.innerHeight / 2;
        let currentId = '';
        for (const el of sections) {
          const r = el.getBoundingClientRect();
          if (r.top <= mid && r.bottom > mid) {
            currentId = el.id;
            const bg = getComputedStyle(el).backgroundColor;
            if (bg && bg !== 'rgba(0, 0, 0, 0)' && bg !== 'transparent') {
              document.documentElement.style.backgroundColor = bg;
              document.body.style.backgroundColor = bg;
              themeMeta.setAttribute('content', bg);
            }
            break;
          }
        }
        if (currentId) {
          const navLinksEls = header.querySelectorAll<HTMLAnchorElement>('a[data-nav-link]');
          navLinksEls.forEach((link) => {
            if (link.hash === `#${currentId}`) link.setAttribute('data-active', '');
            else link.removeAttribute('data-active');
          });
        }
      }
      lastY = y;
    };

    const onScroll = () => {
      if (!ticking) {
        ticking = true;
        requestAnimationFrame(frame);
      }
    };
    frame();
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', () => requestAnimationFrame(frame), { passive: true });
    mq.addEventListener('change', frame);
  }
</script>
