---
import { Phone, CalendarHeart } from 'lucide-react';
import { business, booking, navLinks, baseUrl } from '../../data/siteData';
import BrandMark from '../BrandMark.astro';
import MobileNav from '../react/MobileNav.tsx';
---

<!--
  Translucent glass header banner. On phones it hides/shows with a GPU-composited transform
  transition. Adapts dynamically to light/dark sections below it so system UI (Dynamic Island,
  status bar, Safari bottom bar) seamlessly blends edge-to-edge.
-->
<header
  id="site-header"
  class="fixed inset-x-0 top-0 z-30 bg-sand/80 text-ink border-b border-black/5 pt-[env(safe-area-inset-top)] transition-[translate,box-shadow,background-color,color,border-color] duration-500 ease-[cubic-bezier(0.4,0,0.2,1)] will-change-transform data-[hidden]:-translate-y-full data-[scrolled]:shadow-md data-[scrolled]:shadow-charcoal/5 backdrop-blur-lg backdrop-saturate-150 data-[dark]:bg-charcoal/85 data-[dark]:text-sand data-[dark]:border-white/10"
>
  <div class="container-px flex h-16 items-center justify-between gap-4 xl:gap-6">
    <!-- Brand -->
    <a href={`${baseUrl}#top`} aria-label="Forest Spa home" class="flex items-center">
      <BrandMark variant="horizontal" class="h-12 w-auto sm:h-14 header-logo" />
    </a>

    <!-- Desktop nav -->
    <nav aria-label="Primary" class="hidden lg:flex lg:items-center lg:gap-4 xl:gap-5">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            data-nav-link
            class="whitespace-nowrap text-sm font-medium text-current transition-colors hover:text-bronze data-[active]:font-semibold data-[active]:text-gold"
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <!-- Desktop CTAs -->
    <div class="hidden lg:flex lg:items-center lg:gap-3">
      <a
        href={business.phoneHref}
        data-call="header"
        class="btn btn-outline hidden px-5 py-2.5 text-sm xl:inline-flex border-current text-current"
        aria-label={`Call Forest Spa at ${business.phone}`}
      >
        <Phone size={17} strokeWidth={1.6} />
        <span>{business.phone}</span>
      </a>
      <a
        href={booking.primary}
        target="_blank"
        rel="noopener"
        data-book="header"
        class="btn btn-primary px-5 py-2.5 text-sm"
      >
        <CalendarHeart size={17} strokeWidth={1.6} /> Book Now
      </a>
    </div>

    <!-- Mobile nav island -->
    <MobileNav
      client:media="(max-width: 1023px)"
      links={navLinks}
      bookUrl={booking.primary}
      phone={business.phone}
      phoneHref={business.phoneHref}
    />
  </div>
</header>

<script>
  const header = document.getElementById('site-header');
  const themeMeta = document.querySelector('meta[name="theme-color"]');
  const sections = Array.from(document.querySelectorAll('section, footer'));

  const isDarkColor = (rgbStr: string) => {
    if (!rgbStr) return false;
    const match = rgbStr.match(/\d+/g);
    if (!match || match.length < 3) return false;
    const [r, g, b] = match.map(Number);
    const brightness = (r * 299 + g * 587 + b * 114) / 1000;
    return brightness < 128;
  };

  if (header) {
    const mq = window.matchMedia('(max-width: 1023px)');
    let lastY = Math.max(0, window.scrollY);
    let ticking = false;

    const frame = () => {
      ticking = false;
      const y = Math.max(0, window.scrollY);
      if (y > 8) header.setAttribute('data-scrolled', '');
      else header.removeAttribute('data-scrolled');

      // Smooth compositor-driven hide/show, toggled by scroll direction (phones).
      if (mq.matches && !document.body.classList.contains('drawer-open')) {
        if (y > lastY + 4 && y > 90) header.setAttribute('data-hidden', ''); // down → hide
        else if (y < lastY - 4 || y < 90) header.removeAttribute('data-hidden'); // up / top → show
      } else {
        header.removeAttribute('data-hidden');
      }

      // Dynamic Section Background & System Theme-Color Synchronization
      if (sections.length) {
        const headerRect = header.getBoundingClientRect();
        const checkY = headerRect.bottom + 10;
        let activeSection = null;
        let activeId = '';

        for (const el of sections) {
          const r = el.getBoundingClientRect();
          if (r.top <= checkY && r.bottom > checkY) {
            activeSection = el;
            activeId = el.id;
            break;
          }
        }

        if (activeSection) {
          const bg = getComputedStyle(activeSection).backgroundColor;
          if (bg && bg !== 'rgba(0, 0, 0, 0)' && bg !== 'transparent') {
            document.documentElement.style.backgroundColor = bg;
            document.body.style.backgroundColor = bg;
            if (themeMeta) themeMeta.setAttribute('content', bg);

            if (isDarkColor(bg)) {
              header.setAttribute('data-dark', '');
            } else {
              header.removeAttribute('data-dark');
            }
          }
        }

        if (activeId) {
          const navLinksEls = header.querySelectorAll<HTMLAnchorElement>('a[data-nav-link]');
          navLinksEls.forEach((link) => {
            if (link.hash === `#${activeId}`) link.setAttribute('data-active', '');
            else link.removeAttribute('data-active');
          });
        }
      }
      lastY = y;
    };

    const onScroll = () => {
      if (!ticking) {
        ticking = true;
        requestAnimationFrame(frame);
      }
    };
    frame();
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', () => requestAnimationFrame(frame), { passive: true });
    mq.addEventListener('change', frame);
  }
</script>
