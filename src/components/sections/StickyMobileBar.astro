---
import { Phone, CalendarHeart } from 'lucide-react';
import { business, booking } from '../../data/siteData';
---

<div
  id="mobile-sticky-bar"
  class="lg:hidden fixed inset-x-0 bottom-0 z-30 border-t border-black/10 bg-cloud/95 shadow-[0_-8px_28px_-18px_rgba(46,46,43,0.5)] backdrop-blur px-4 pt-3 pb-[calc(0.75rem+env(safe-area-inset-bottom))]"
>
  <div class="mx-auto flex max-w-md items-center gap-3">
    <a href={business.phoneHref} data-call="sticky" class="btn btn-outline flex-1">
      <Phone size={18} strokeWidth={1.6} /> Call Us
    </a>
    <a
      href={booking.primary}
      target="_blank"
      rel="noopener"
      data-book="sticky"
      class="btn btn-primary flex-1"
    >
      <CalendarHeart size={18} strokeWidth={1.6} /> Book Now
    </a>
  </div>
</div>
