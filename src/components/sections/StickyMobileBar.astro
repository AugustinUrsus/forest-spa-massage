---
import { Phone, CalendarHeart } from 'lucide-react';
import { business, booking } from '../../data/siteData';
---

<!-- Transparent bar: no banner, just the two buttons floating with a soft bloom. -->
<div
  id="mobile-sticky-bar"
  class="lg:hidden fixed inset-x-0 bottom-0 z-30 px-4 pt-3 pb-[calc(0.75rem+env(safe-area-inset-bottom))]"
>
  <div class="mx-auto flex max-w-md items-center gap-3">
    <a
      href={business.phoneHref}
      data-call="sticky"
      class="btn flex-1 border border-black/10 bg-cloud text-ink shadow-[0_0_26px_2px_rgba(46,46,43,0.28)]"
    >
      <Phone size={18} strokeWidth={1.6} /> Call Us
    </a>
    <a
      href={booking.primary}
      target="_blank"
      rel="noopener"
      data-book="sticky"
      class="btn btn-primary flex-1 shadow-[0_0_26px_2px_rgba(107,92,53,0.5)]"
    >
      <CalendarHeart size={18} strokeWidth={1.6} /> Book Now
    </a>
  </div>
</div>
