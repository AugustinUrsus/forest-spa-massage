---
import { Image } from 'astro:assets';
import { CalendarHeart, ArrowDown, ArrowRight, Sparkles, Gift } from 'lucide-react';
import { business, booking, monthlySpecial } from '../../data/siteData';
import heroImg from '../../assets/images/hero-ambiance.jpg';
---

<section
  id="top"
  class="relative flex min-h-[92svh] items-center overflow-hidden bg-charcoal text-sand"
>
  <!-- Background photo (LCP). On mobile the focal point shifts right so the
       candles show; text sits over the darkened left. -->
  <Image
    src={heroImg}
    alt=""
    aria-hidden="true"
    class="absolute inset-0 h-full w-full object-cover object-[64%_center] sm:object-center"
    widths={[768, 1280, 1920, 2600]}
    sizes="100vw"
    loading="eager"
    fetchpriority="high"
  />
  <!-- Legibility overlays -->
  <div class="absolute inset-0 bg-gradient-to-r from-charcoal-deep/85 via-charcoal/65 to-charcoal/25"></div>
  <div class="absolute inset-x-0 bottom-0 h-24 bg-gradient-to-b from-transparent to-sand-deep"></div>

  <div class="container-px relative z-10 py-28 lg:py-32">
    <div class="max-w-2xl">
      <a
        href="#specials"
        class="group mb-6 inline-flex items-center gap-2 rounded-full border border-gold/40 bg-gold/10 py-1.5 pl-4 pr-3 text-sm font-medium text-gold backdrop-blur transition-colors hover:bg-gold/20"
      >
        <Sparkles size={15} />
        <span>
          {monthlySpecial.month} · {monthlySpecial.name} — ${monthlySpecial.price}
          <span class="text-gold/60 line-through">${monthlySpecial.value}</span>
        </span>
        <ArrowRight size={15} className="transition-transform duration-300 group-hover:translate-x-0.5" />
      </a>

      <p class="eyebrow mb-5 text-gold">{business.tagline}</p>

      <h1 class="display-heading text-4xl leading-[1.08] sm:text-5xl lg:text-6xl">
        {business.headline}
      </h1>

      <!-- Subhead: hidden on mobile, shown from sm up -->
      <p class="mt-6 hidden max-w-xl text-lg leading-relaxed text-sand/85 sm:block sm:text-xl">
        {business.subhead}
      </p>

      <div class="mt-9 flex flex-wrap items-center gap-4">
        <a
          href={booking.primary}
          target="_blank"
          rel="noopener"
          data-book="hero"
          class="btn btn-primary"
        >
          <CalendarHeart size={19} /> Book Appointment
        </a>
        <a href="#services" class="btn btn-ghost-dark">
          Explore Services <ArrowDown size={17} />
        </a>
        <a
          href={booking.giftCards}
          target="_blank"
          rel="noopener"
          data-book="hero-giftcard"
          class="btn btn-ghost-dark"
        >
          <Gift size={17} /> Gift Cards
        </a>
      </div>
    </div>
  </div>
</section>
