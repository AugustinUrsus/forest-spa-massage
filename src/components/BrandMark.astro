---
import { Image } from 'astro:assets';
import horizontal from '../assets/images/logo-horizontal.png';
import stackedLight from '../assets/images/logo-stacked-light.png';

/**
 * Forest Spa logo — renders the real brand artwork (from /Artwork/Logos),
 * optimized via astro:assets. Two variants:
 *   horizontal    → dark wordmark, for light backgrounds (header, drawer)
 *   stacked-light → sage/gold emblem + wordmark, reads on dark (footer)
 */
interface Props {
  variant?: 'horizontal' | 'stacked-light';
  class?: string;
  alt?: string;
}
const { variant = 'horizontal', class: className = '', alt = 'Forest Spa' } = Astro.props;
const src = variant === 'stacked-light' ? stackedLight : horizontal;
---

<Image src={src} alt={alt} class={className} loading="eager" densities={[1, 2]} />
