---
import Layout from '../layouts/Layout.astro';
import Header from '../components/sections/Header.astro';
import Footer from '../components/sections/Footer.astro';
import { legal } from '../data/siteData';
---

<Layout
  title={`${legal.title} | Forest Spa`}
  description="Forest Spa privacy policy and terms — how we collect, use, and protect your personal information."
>
  <Header />
  <main id="main" class="bg-cloud pb-[var(--spacing-section)] pt-32 sm:pt-36">
    <article class="container-px reveal">
      <header class="mx-auto max-w-3xl text-center">
        <p class="eyebrow mb-4">Forest Spa</p>
        <h1 class="display-heading text-4xl sm:text-5xl">{legal.title}</h1>
        <p class="mt-6 text-lg leading-relaxed text-ink-soft">{legal.intro}</p>
      </header>

      <div class="mx-auto mt-14 max-w-3xl space-y-10">
        {
          legal.sections.map((s) => (
            <section>
              <h2 class="display-heading text-xl text-ink sm:text-2xl">{s.heading}</h2>
              <p class="mt-3 leading-relaxed text-ink-soft">{s.body}</p>
            </section>
          ))
        }
      </div>

      <div class="mx-auto mt-16 max-w-3xl">
        <a href="/" class="btn btn-outline">← Back to Forest Spa</a>
      </div>
    </article>
  </main>
  <Footer />
</Layout>
