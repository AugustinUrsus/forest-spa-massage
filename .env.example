# Analytics (optional). Copy to `.env` and fill in to enable tracking.
# Leave unset and the GA4 / Google Ads / Meta Pixel tags will not render.
PUBLIC_GA4_ID=
PUBLIC_META_PIXEL_ID=

# Google Ads (optional) — conversion tracking for booking clicks.
PUBLIC_GOOGLE_ADS_ID=
PUBLIC_GOOGLE_ADS_BOOKING_LABEL=

# Deployment target (optional overrides — defaults target the custom domain at root).
# SITE_URL=https://www.forestspamassage.com
# BASE_PATH=/
